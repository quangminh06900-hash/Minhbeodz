    local function openFullscreen(item, itemName, count)
        fullTitleLabel.Text = itemName .. " x" .. count
        
        for _, child in pairs(fullViewportFrame:GetChildren()) do
            if child:IsA("Model") then
                child:Destroy()
            end
        end
        
        local model
        if item:IsA("Model") then
            model = item:Clone()
            model.Parent = fullViewportFrame
        elseif item:IsA("BasePart") then
            model = Instance.new("Model")
            local clone = item:Clone()
            clone.Parent = model
            model.PrimaryPart = clone
            model.Parent = fullViewportFrame
        end
        
        if not model then return end
        
        local cf, size = model:GetBoundingBox()
        local maxDim = math.max(size.X, size.Y, size.Z)
        local distance = maxDim * 2.5
        
        local rotationX, rotationY = -15, 0
        local dragging = false
        local hovering = false
        local lastPos = Vector2.zero
        
        local function updateCamera()
            local center = cf.Position
            local offset = CFrame.new(0, 0, distance)
            local rotation = CFrame.Angles(0, math.rad(rotationY), 0) * CFrame.Angles(math.rad(rotationX), 0, 0)
            local camCF = CFrame.new(center) * rotation * offset
            fullCamera.CFrame = CFrame.lookAt(camCF.Position, center)
        end
        
        local connections = {}
        
        table.insert(connections, fullViewportFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 
            or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                lastPos = input.Position
            end
        end))
        
        table.insert(connections, fullViewportFrame.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end))
        
        table.insert(connections, fullViewportFrame.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - lastPos
                lastPos = input.Position
                rotationY = rotationY - delta.X * 0.5
                rotationX = math.clamp(rotationX - delta.Y * 0.5, -80, 80)
            end
            if input.UserInputType == Enum.UserInputType.MouseWheel and hovering then
                distance = math.clamp(distance - (input.Position.Z * 2), maxDim * 0.5, maxDim * 10)
            end
        end))
        
        table.insert(connections, fullViewportFrame.MouseEnter:Connect(function()
            hovering = true
        end))
        
        table.insert(connections, fullViewportFrame.MouseLeave:Connect(function()
            hovering = false
        end))
        
        local renderConn
        renderConn = RunService.RenderStepped:Connect(function()
            if model and fullCamera and fullscreenFrame.Visible then
                if not dragging then
                    rotationY = rotationY + 0.008 * 60
                end
                updateCamera()
            end
        end)
        table.insert(connections, renderConn)
        
        local function closeFullscreen()
            for _, conn in pairs(connections) do
                conn:Disconnect()
            end
            TweenService:Create(viewerBlur, TweenInfo.new(0.2), {Size = 0}):Play()
            mainFrame.Visible = true
            
